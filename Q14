import java.util.Scanner;
import Q14pack.Library;

public class Q14 {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        System.out.print("Enter total number of books: ");
        int n = sc.nextInt();
        sc.nextLine();

        Library l = new Library(n);

        l.acceptBooks();

        System.out.println("\nLibrary Books:");
        l.displayBooks();

        System.out.print("\nEnter book name to search: ");
        String bname = sc.nextLine();
        l.searchBook(bname);

        System.out.print("\nEnter author name to count books: ");
        String aname = sc.nextLine();
        l.countBooksByAuthor(aname);

        sc.close();
    }
}
